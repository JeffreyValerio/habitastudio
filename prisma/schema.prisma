// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String?
  password        String
  role            String        @default("moderator") // admin, moderator, collaborator
  isCollaborator  Boolean       @default(false)
  hourlyRate      Float?        // Tarifa por hora (si es colaborador)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relaciones
  timeEntries          TimeEntry[]
  assignments          ProjectAssignment[]
  payrolls             Payroll[]
  approvals            TimeApproval[]
  workOrderAssignments WorkOrderAssignment[]
  workOrderExpenses    WorkOrderExpense[]
  materialMovements    MaterialMovement[]
  rateHistory          CollaboratorRate[]
}

// Tarifa por hora vigente a partir de un mes específico (y hasta que se
// fije una nueva). Permite variaciones de tarifa a lo largo del tiempo
// sin perder el cálculo correcto de pagos ya generados en meses pasados.
model CollaboratorRate {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year       Int
  month      Int      // 1-12
  hourlyRate Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId])
}

model UserInvitation {
  id             String    @id @default(cuid())
  email          String
  role           String    @default("moderator")
  token          String    @unique
  accepted       Boolean   @default(false)
  isCollaborator Boolean   @default(false)
  hourlyRate     Float?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  updatedAt      DateTime  @updatedAt

  @@unique([email, token])
}

model TimeEntry {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workOrderId  String?
  workOrder    WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  workType     String?    // corte, encintado, instalacion, armado
  entryDate    DateTime  // Fecha de entrada
  entryTime    DateTime  // Hora de entrada
  exitTime     DateTime? // Hora de salida
  description  String?   // Descripción del trabajo
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relación con aprobación
  approvals    TimeApproval[]

  @@index([userId])
  @@index([workOrderId])
  @@index([entryDate])
}

model TimeApproval {
  id           String    @id @default(cuid())
  timeEntryId  String
  timeEntry    TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  type         String    // "entry" o "exit"
  status       String    @default("pending") // pending, approved, rejected
  approvedBy   String?
  approver     User?     @relation(fields: [approvedBy], references: [id], onDelete: SetNull)
  rejectionReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([timeEntryId, type])
  @@index([status])
  @@index([approvedBy])
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // ej: "carpintero", "pintor", "ensamblador"
  status    String   @default("assigned") // assigned, in-progress, completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
}

model Payroll {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  period          String    // "2024-06" formato año-mes
  totalHours      Float     @default(0)
  hourlyRate      Float
  grossPay        Float     @default(0)
  deductions      Float     @default(0)
  netPay          Float     @default(0)
  status          String    @default("pending") // pending, approved, paid
  paidDate        DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, period])
  @@index([userId])
}

// ============ CRM MODELS ============

model Customer {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  phone            String?
  company          String?
  position         String?
  address          String?   @db.Text
  city             String?
  country          String?

  // CRM Fields
  status           String    @default("prospect") // prospect, qualified, negotiation, customer, inactive
  source           String?   // website, referral, cold-call, social, event, etc
  totalSpent       Float     @default(0)
  estimatedValue   Float     @default(0)
  lastInteraction  DateTime?
  nextFollowUp     DateTime?
  score            Int       @default(0) // 0-100 scoring

  // Relationships
  quotes           Quote[]
  interactions     CustomerInteraction[]
  notes            CustomerNote[]
  tags             CustomerTag[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([email])
  @@index([company])
}

model CustomerInteraction {
  id               String    @id @default(cuid())
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type             String    // email, call, meeting, proposal, demo, etc
  subject          String
  notes            String?   @db.Text
  outcome          String?   // interested, not-interested, follow-up-needed, closed

  duration         Int?      // minutes (for calls/meetings)
  participants     String[]  @default([]) // emails of participants

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([customerId])
  @@index([type])
  @@index([createdAt])
}

model CustomerNote {
  id               String    @id @default(cuid())
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title            String
  content          String    @db.Text
  priority         String    @default("normal") // low, normal, high

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([customerId])
  @@index([priority])
}

model CustomerTag {
  id               String    @id @default(cuid())
  name             String    @unique
  color            String    @default("#3b82f6")
  customers        Customer[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ============ END CRM MODELS ============

// ============ INVENTARIO (materia prima) ============

model Supplier {
  id           String    @id @default(cuid())
  name         String
  email        String?
  phone        String?
  address      String?   @db.Text
  city         String?
  country      String?
  paymentTerms String?   // net30, net60, etc
  isActive     Boolean   @default(true)

  materials    Material[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive])
}

model Material {
  id           String    @id @default(cuid())
  name         String
  unit         String    // unidad, m2, ml, kg
  costPerUnit  Float     @default(0)
  quantity     Float     @default(0)
  minimumStock Float     @default(0)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  notes        String?   @db.Text

  movements    MaterialMovement[]
  expenses     WorkOrderExpense[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([supplierId])
}

model MaterialMovement {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  type       String   // in (compra/ajuste), out (consumo/ajuste)
  quantity   Float
  reference  String?  // ej. número de orden de trabajo, o "Compra manual"
  notes      String?  @db.Text

  createdBy  String
  creator    User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([materialId])
  @@index([type])
}

// ============ END ERP MODELS ============

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  cost        Float    @default(0)
  price       Float
  image       String
  gallery     String[] @default([])
  description String   @db.Text
  features    String[] @default([])
  material    String?
  dimensions  String?
  color       String?
  warranty    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String   @db.Text
  longDescription String   @db.Text
  image           String?
  features        String[] @default([])
  process         String[] @default([])
  benefits        String[] @default([])
  icon            String   @default("Home")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Project {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String   @db.Text
  longDescription String   @db.Text
  image           String
  category        String
  year            String
  location        String?
  duration        String?
  challenges      String[] @default([])
  solutions       String[] @default([])
  gallery         String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  assignments     ProjectAssignment[]
}

model Quote {
  id                 String      @id @default(cuid())
  quoteNumber        String      @unique

  // Customer relationship
  customerId         String?
  customer           Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Legacy fields (for backward compatibility)
  clientName         String
  clientEmail        String?
  clientPhone        String?
  clientAddress      String?     @db.Text
  projectName        String
  projectDescription String?     @db.Text
  status             String      @default("draft") // draft, sent, accepted, rejected, expired
  validUntil         DateTime?
  subtotal           Float       @default(0)
  tax                Float       @default(0)
  discount           Float       @default(0)
  total              Float       @default(0)
  notes              String?     @db.Text
  images             String[]    @default([])
  sentAt             DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  items              QuoteItem[]
  receipts           Receipt[]
  workOrder          WorkOrder?

  @@index([customerId])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  total       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quoteId])
}

model QuoteSequence {
  year       Int      @id
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model Receipt {
  id            String    @id @default(cuid())
  receiptNumber String    @unique
  quoteId       String
  quote         Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  clientName    String
  clientEmail   String?
  amount        Float
  paymentMethod String    // efectivo, transferencia, sinpe, cheque, otro
  receiptDate   DateTime  @default(now())
  concept       String    @db.Text
  notes         String?   @db.Text
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([quoteId])
}

model ReceiptSequence {
  year       Int      @id
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model WorkOrder {
  id              String    @id @default(cuid())
  workOrderNumber String    @unique
  quoteId         String    @unique
  quote           Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  status          String    @default("pending") // pending, in_progress, completed
  deliveryDate    DateTime? // Fecha de compromiso de entrega; libera la orden al taller
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments     WorkOrderAssignment[]
  timeEntries     TimeEntry[]
  expenses        WorkOrderExpense[]

  @@index([status])
}

model WorkOrderExpense {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  category    String    // materiales, transporte, mano_obra_externa, otros
  description String
  amount      Float
  quantity    Float?    // cantidad usada, si el gasto viene de un material de inventario
  materialId  String?
  material    Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  expenseDate DateTime  @default(now())
  createdBy   String
  creator     User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workOrderId])
  @@index([materialId])
}

model WorkOrderAssignment {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workType    String    // corte, encintado, instalacion, armado
  createdAt   DateTime  @default(now())

  @@unique([workOrderId, userId, workType])
  @@index([userId])
  @@index([workOrderId])
}

model WorkOrderSequence {
  year       Int      @id
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}
